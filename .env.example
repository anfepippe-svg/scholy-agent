# =====================================================================
# SCHOLY AGENT - Plantilla de variables de entorno
# ---------------------------------------------------------------------
# 1. Copia este archivo a ".env"  ->  cp .env.example .env
# 2. Rellena los valores reales en ".env" (NUNCA en este archivo).
# 3. ".env" está ignorado por git: tus secretos jamás se suben al repo.
# =====================================================================

# --- Autenticación de Gemini (Google AI Studio, capa gratuita) -------
# Crea una API key gratis en https://aistudio.google.com/apikey
# Esta es la ÚNICA credencial obligatoria para correr el MVP en local.
GOOGLE_API_KEY=tu_api_key_de_google_ai_studio

# Indica al ADK que use la API de Gemini (no Vertex AI, que requiere facturación).
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# --- Modelo por defecto ----------------------------------------------
# Modelo económico usado en el curso. Puedes cambiarlo si lo necesitas.
SCHOLY_MODEL=gemini-2.5-flash-lite

# --- Búsqueda externa (OPCIONAL, solo para V2 vía MCP) ---------------
# Déjalo vacío para el MVP. Si algún día activas un MCP de búsqueda
# externa (p. ej. Tavily/Serper), pon aquí su key. No es necesaria ahora.
SCHOLY_EXTERNAL_SEARCH_API_KEY=
